# Postgres connection (matches docker-compose.yml; host port 5433 to avoid a local Postgres on 5432)
DATABASE_URL=postgresql://cafe:cafe@127.0.0.1:5433/cafepos

# Auth.js — generate with: openssl rand -base64 33
AUTH_SECRET=replace-me
AUTH_URL=http://localhost:3000

# Absolute app URL used for email and digital receipt links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend email receipts. Leave API key empty locally to no-op receipt email.
RESEND_API_KEY=
RESEND_FROM="Cafe POS <receipts@example.com>"

# Demo receipt branding
RECEIPT_BRAND_NAME="Parul Cafe"
RECEIPT_BRAND_ADDRESS="Vadodara, Gujarat"
RECEIPT_BRAND_FOOTER="Thank you for dining with us."
RECEIPT_PREP_MINUTES=15

# Shared kitchen screen PIN
KDS_PIN=2468

# OpenAI AI insights
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
